# Прод-окружение STAW backend.
# СКОПИРОВАТЬ в backend/.env (он в .gitignore — НЕ коммитить!) и ЗАПОЛНИТЬ.
# Сильные секреты: python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# Без заполнения секретов приложение НЕ стартует (fail-fast, common/prodcheck.py).

# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=ЗАМЕНИ_сильным_секретом
JWT_SECRET=ЗАМЕНИ_ДРУГИМ_сильным_секретом
DJANGO_ALLOWED_HOSTS=api.staw.ru
# Откуда фронт/сайт ходят (CORS + CSRF для админки за HTTPS):
DJANGO_CORS_ORIGINS=https://staw.ru,https://www.staw.ru

# ── PostgreSQL/PostGIS ──────────────────────────────────────────────────────
POSTGRES_DB=staw
POSTGRES_USER=staw
POSTGRES_PASSWORD=ЗАМЕНИ_сильным_паролем_БД
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Sentry (мониторинг/краши, D-25: self-host РФ) ────────────────────────────
# Без DSN Sentry не подключается (no-op). Заполнить, когда поднят self-host Sentry.
# SENTRY_DSN=https://<key>@sentry.staw.ru/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0

# ── Прочее ──────────────────────────────────────────────────────────────────
# Демо-баллы новичкам — в проде НЕ задавать (по умолчанию выкл). Только для демо: =1
# SEED_DEMO_POINTS=1
DJANGO_MEDIA_ROOT=/srv/media
DJANGO_STATIC_ROOT=/app/staticfiles
