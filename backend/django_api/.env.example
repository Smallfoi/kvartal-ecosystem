# Скопируй в .env при локальном запуске вне docker-compose (в compose значения заданы там).
# --- DEV (по умолчанию) ---
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-secret-change-in-prod
POSTGRES_DB=kvartal
POSTGRES_USER=kvartal
POSTGRES_PASSWORD=kvartal
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- ПРОД (заполнить при деплое; в dev оставить закомментированным) ---
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=<длинный-случайный-секрет, напр. `python -c "import secrets;print(secrets.token_urlsafe(50))"`>
# DJANGO_ALLOWED_HOSTS=api.staw.ru,staw.ru          # хосты, с которых принимаем запросы
# DJANGO_CORS_ORIGINS=https://staw.ru,https://www.staw.ru  # источники сайта (со схемой)
# POSTGRES_PASSWORD=<сильный-пароль-БД>
